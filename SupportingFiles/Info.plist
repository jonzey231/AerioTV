<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>$(PRODUCT_BUNDLE_IDENTIFIER).refresh</string>
	</array>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>app.molinete.aerio</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>aerio</string>
			</array>
		</dict>
	</array>
	<key>CFBundleDisplayName</key>
	<string>AerioTV</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSApplicationCategoryType</key>
	<string></string>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>
	<!--
	  v1.6.9: Comprehensive ATS exemption.

	  Aerio is a generic IPTV / VOD client — users connect to any
	  reseller-provided server, the vast majority of which run plain
	  HTTP without TLS. Refusing those connections at the OS layer
	  effectively breaks the app for that audience, so we opt out of
	  the default ATS posture entirely.

	  Why every key is explicit:
	    • NSAllowsArbitraryLoads — turns ATS off for every domain.
	      In theory sufficient on its own.
	    • NSAllowsArbitraryLoadsInWebContent — covers WKWebView /
	      SFSafariViewController loads (none today, but defensive
	      against future in-app web content; Apple has tightened
	      web-content ATS interaction in recent iOS releases).
	    • NSAllowsArbitraryLoadsForMedia — covers AVFoundation /
	      AVPlayer media URLs. mpv-rendered streams don't go through
	      AVPlayer, but iOS sometimes queries AVAssetResourceLoader
	      for poster / thumbnail work and that path respects this
	      flag separately from the global one.
	    • NSAllowsLocalNetworking — keeps Bonjour / .local URLs
	      working when a stricter ATS posture is enforced via
	      system policy mid-session.

	  v1.6.8 shipped with only NSAllowsArbitraryLoads + NSAllowsLocalNetworking.
	  Multiple users hit `NSURLErrorAppTransportSecurityRequiresSecureConnection`
	  (-1022) when adding Xtream Codes servers over HTTP. Adding the
	  two arbitrary-content keys closes whichever path was still
	  being gated. Belt-and-suspenders here is the right call —
	  there's no upside to a narrower ATS policy in this app.
	-->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
		<key>NSAllowsArbitraryLoadsInWebContent</key>
		<true/>
		<key>NSAllowsArbitraryLoadsForMedia</key>
		<true/>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>NSLocalNetworkUsageDescription</key>
	<string>AerioTV needs local network access to connect to your media server on your home network.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Used only when you tap Detect WiFi. iOS gates the WiFi network name behind Location permission; AerioTV reads it so it can automatically switch between your local and remote server URLs when you come home.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>processing</string>
		<string>fetch</string>
	</array>
	<key>UIFileSharingEnabled</key>
	<true/>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string></string>
	</dict>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
	</array>
	<key>UISupportsDocumentBrowser</key>
	<false/>
</dict>
</plist>
